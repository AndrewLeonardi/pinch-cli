{
  "name": "pinch-cli",
  "version": "0.2.0",
  "description": "The fastest way to build, test, and deploy MCP servers. Open source CLI for the Model Context Protocol.",
  "bin": { "pinch": "./dist/index.js" },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "ai-tools",
    "mcp-server",
    "llm",
    "agents",
    "claude",
    "openai",
    "chatgpt",
    "developer-tools",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AndrewLeonardi/pinch-cli.git"
  },
  "homepage": "https://github.com/AndrewLeonardi/pinch-cli#readme",
  "bugs": {
    "url": "https://github.com/AndrewLeonardi/pinch-cli/issues"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "inquirer": "^12.6.0",
    "open": "^10.1.0",
    "toml": "^3.0.0",
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.0"
  },
  "engines": { "node": ">=18" },
