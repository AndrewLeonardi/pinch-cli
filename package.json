{
  "name": "pinch-cli",
  "version": "1.0.0",
  "description": "Build, test, and deploy MCP servers with custom frontends — from your terminal.",
  "bin": {
    "pinch": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "mcp",
    "model-context-protocol",
    "ai",
    "ai-tools",
    "mcp-server",
    "llm",
    "agents",
    "developer-tools",
    "typescript",
    "cloudflare-workers",
    "deploy"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewLeonardi/pinch-cli.git"
  },
  "homepage": "https://pinchers.ai",
  "bugs": {
    "url": "https://github.com/AndrewLeonardi/pinch-cli/issues"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "inquirer": "^12.6.0",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
