{
  "name": "pinch-cli",
  "version": "2.0.0",
  "description": "The simplest way to learn MCP and launch an MCP product.",
  "bin": {
    "pinch": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/ui.html dist/",
    "dev": "tsc && cp src/ui.html dist/ && node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "cli",
    "mcp",
    "model-context-protocol",
    "ai",
    "ai-tools",
    "mcp-server",
    "llm",
    "agents",
    "developer-tools",
    "typescript",
    "cloudflare-workers"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewLeonardi/pinch-cli.git"
  },
  "homepage": "https://pinchers.ai",
  "bugs": {
    "url": "https://github.com/AndrewLeonardi/pinch-cli/issues"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
